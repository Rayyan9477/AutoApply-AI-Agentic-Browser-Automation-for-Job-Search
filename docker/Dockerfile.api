# Production API image — slim, no dev/test tooling, NO Chromium (browser runs in the worker).
FROM python:3.11-slim

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1

# WeasyPrint (PDF render) + spaCy (ATS scoring) runtime libraries.
RUN apt-get update && apt-get install -y --no-install-recommends \
    libpango-1.0-0 libpangocairo-1.0-0 libgdk-pixbuf2.0-0 \
    libffi-dev libcairo2 libglib2.0-0 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY backend/pyproject.toml ./
COPY backend/app/ ./app/
# Jinja/WeasyPrint document templates live at the repo root (build context is repo root);
# the DocumentGenerator resolves them via a relative "templates" path from the CWD (/app).
COPY templates/ ./templates/

# Production deps only (postgres + aws/S3 extras; NOT [dev]).
RUN pip install ".[postgres,aws]" \
    && python -m spacy download en_core_web_sm

RUN useradd -m appuser && mkdir -p /app/data && chown -R appuser:appuser /app
USER appuser

EXPOSE 8000
# --proxy-headers + --forwarded-allow-ips="*" so request.client.host reflects the real client
# IP from Caddy's X-Forwarded-For (else the rate limiter keys every request on Caddy's container
# IP → one global bucket). Safe because compose uses `expose`, not `ports`: only Caddy can reach
# this port, so clients cannot spoof the forwarded header.
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000", "--workers", "2", \
     "--proxy-headers", "--forwarded-allow-ips", "*"]
