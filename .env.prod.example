# ── Production environment (copy to .env.prod; NEVER commit the real file) ──────────────
# Generate secrets:
#   AUTH__SECRET_KEY:    python -c "import secrets; print(secrets.token_urlsafe(48))"
#   SECRETS__APP_KEYS:   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#   METRICS_TOKEN:       python -c "import secrets; print(secrets.token_urlsafe(24))"

ENVIRONMENT=production
LOG_LEVEL=INFO

# ── Database — Neon Postgres (free tier). asyncpg uses the `ssl` query param, NOT libpq
#    `sslmode` (writing ?sslmode=require makes asyncpg raise TypeError at first connect). ─────
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/autoapply?ssl=require

# ── Redis — the in-stack container ──────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Auth ────────────────────────────────────────────────────────────────────────────────
AUTH__SECRET_KEY=CHANGE_ME_long_random_string

# ── Secrets-at-rest (Fernet envelope; first key is the current KEK, comma-separated) ─────
SECRETS__PROVIDER=local
SECRETS__APP_KEYS=CHANGE_ME_fernet_key

# ── Object storage — Cloudflare R2 (S3-compatible). Create a bucket + an R2 API token. ──
STORAGE__PROVIDER=s3
STORAGE__BUCKET=autoapply
STORAGE__REGION=auto
STORAGE__ENDPOINT_URL=https://ACCOUNT_ID.r2.cloudflarestorage.com
STORAGE__ACCESS_KEY_ID=CHANGE_ME_r2_access_key
STORAGE__SECRET_ACCESS_KEY=CHANGE_ME_r2_secret_key

# ── Metrics scrape token (required to read /metrics in production) ───────────────────────
METRICS_TOKEN=CHANGE_ME_metrics_token

# ── CORS — your frontend origin(s), comma-separated JSON-style list ─────────────────────
CORS_ORIGINS=["https://app.example.com"]

# ── Caddy TLS — the API's public hostname ───────────────────────────────────────────────
DOMAIN=api.example.com

# ── Browser automation — keep the live apply OFF until the assisted-login spike is ready ─
BROWSER__LIVE_APPLY=false
BROWSER__HEADLESS=true
BROWSER__MAX_PARALLEL=1

# ── LLM — per-user BYO keys are primary; these optional globals are a fallback ───────────
# LLM__OPENAI_API_KEY=
# LLM__DEFAULT_MODEL=gpt-4o
