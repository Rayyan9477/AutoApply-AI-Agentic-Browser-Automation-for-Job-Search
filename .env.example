# =============================================================================
# AutoApply AI — Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# --- Database ---
DATABASE_URL=sqlite+aiosqlite:///data/db/autoapply.db
REDIS_URL=redis://localhost:6379/0

# --- LLM Providers (set at least one) ---
LLM__PORTKEY_API_KEY=
LLM__OPENAI_API_KEY=
LLM__GROQ_API_KEY=
LLM__GEMINI_API_KEY=
LLM__OPENROUTER_API_KEY=
LLM__DEEPSEEK_API_KEY=
LLM__GITHUB_TOKEN=

# LLM preferences
LLM__PREFERRED_PROVIDER=openai
# JSON array of fallback provider order
LLM__FALLBACK_PROVIDERS=["groq", "openrouter", "gemini"]
LLM__DEFAULT_MODEL=gpt-4o
LLM__TEMPERATURE=0.7
LLM__MAX_TOKENS=4096

# --- Browser Automation ---
BROWSER__HEADLESS=true
BROWSER__MAX_PARALLEL=3
# To reuse your existing Chrome sessions (LinkedIn, Indeed, etc.):
# Point this to your real Chrome profile directory:
# Windows: C:/Users/<you>/AppData/Local/Google/Chrome/User Data
# Mac: ~/Library/Application Support/Google/Chrome
# Or leave default for a standalone profile:
BROWSER__USER_DATA_DIR=./data/sessions/chrome_profile
BROWSER__KEEP_ALIVE=true
BROWSER__MAX_STEPS=50
BROWSER__MAX_FAILURES=3
BROWSER__STEP_TIMEOUT=120
BROWSER__USE_VISION=auto

# --- Job Discovery ---
# Exa AI semantic search for finding jobs across the web (optional)
EXA_API_KEY=

# --- Application Behavior ---
APPLY_MODE=review
# Options: autonomous, review, batch
MIN_ATS_SCORE=0.75
ENVIRONMENT=development
LOG_LEVEL=INFO

# --- Auth & Security (multi-tenant) ---
# JWT signing secret — MUST be a strong random value in production.
AUTH__SECRET_KEY=dev-insecure-change-me
AUTH__ACCESS_TOKEN_EXPIRE_MINUTES=15
AUTH__REFRESH_TOKEN_EXPIRE_DAYS=30
AUTH__WS_TICKET_EXPIRE_SECONDS=60

# --- Secrets (per-user BYO-key envelope encryption) ---
# Comma-separated Fernet keys (first = current KEK). Generate one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Leave empty outside production to auto-generate an ephemeral dev key.
SECRETS__PROVIDER=local
SECRETS__APP_KEYS=

# --- File Storage ---
STORAGE__PROVIDER=local
STORAGE__LOCAL_ROOT=./data/storage
STORAGE__URL_SIGNING_SECRET=dev-insecure-change-me
# For S3-compatible storage (AWS S3 / Cloudflare R2 / MinIO) set STORAGE__PROVIDER=s3 and:
# STORAGE__BUCKET=autoapply
# STORAGE__REGION=auto
# STORAGE__ENDPOINT_URL=https://<account>.r2.cloudflarestorage.com
# STORAGE__ACCESS_KEY_ID=
# STORAGE__SECRET_ACCESS_KEY=

# --- Server ---
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173"]

# --- Platform Credentials (OPTIONAL if using Chrome profile session reuse) ---
# If BROWSER__USER_DATA_DIR points to your real Chrome profile AND you're
# already logged in to these platforms, you can leave these empty.
# The system will detect and reuse your existing sessions automatically.
#
# Only needed for first-time login or if sessions expire:
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=

INDEED_EMAIL=
INDEED_PASSWORD=

GLASSDOOR_EMAIL=
GLASSDOOR_PASSWORD=
